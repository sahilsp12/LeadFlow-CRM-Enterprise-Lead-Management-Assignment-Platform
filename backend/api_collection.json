            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Client Prospect\",\n  \"email\": \"prospect@test.com\",\n  \"phone\": \"555-0105\",\n  \"source\": \"Google Ads\",\n  \"notes\": \"Initial notes summary.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/leads",
              "host": ["{{baseUrl}}"],
              "path": ["leads"]
