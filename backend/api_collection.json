            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/leads?page=1&limit=10&status=New&sortBy=createdAt&sortOrder=DESC",
              "host": ["{{baseUrl}}"],
              "path": ["leads"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "status", "value": "New" },
                { "key": "sortBy", "value": "createdAt" },
                { "key": "sortOrder", "value": "DESC" }
              ]
            }
          }
        },
