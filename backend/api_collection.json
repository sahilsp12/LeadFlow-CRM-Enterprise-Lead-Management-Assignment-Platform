            },
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"Contacted\",\n  \"notes\": \"Updated conversation with agent.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/leads/:leadId",
              "host": ["{{baseUrl}}"],
              "path": ["leads", ":leadId"],
              "variable": [
                { "key": "leadId", "value": "PLACEHOLDER_UUID" }
